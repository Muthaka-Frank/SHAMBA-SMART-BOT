# Shamba-Smart Environment Variables
# Copy this file to .env and fill in your real values

# ─── Twilio (WhatsApp) ────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=whatsapp:+14155238886

# ─── PostgreSQL Database ───────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://postgres:8845@localhost:5432/shamba_smart

# ─── Paths ────────────────────────────────────────────────────────────────────
VECTOR_STORE_PATH=../DATABASE/vector_store
KNOWLEDGE_BASE_PATH=../DATABASE/knowledge_base
AUDIO_TMP_PATH=./tmp_audio

# ─── App Config ───────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_PORT=5000
